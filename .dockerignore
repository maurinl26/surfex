# Contexte Docker minimal
.git
.github
**/__pycache__
python/dist
python/build
python/.mesonpy-*
**/*.egg-info
.venv
testvenv

# Artefacts de build (regénérés dans l'image)
src/dir_obj-*
conf/profile_surfex*
exe/*
!exe/empty.txt

# Arbres tiers déjà extraits (regénérés par configure : SPARTACUS/MEGAN sont
# détarrés inconditionnellement — on GARDE donc leurs .tar.gz dans le contexte).
src/LIB/SPARTACUS
src/LIB/MEGAN
src/LIB/eccodes-*-Source
src/LIB/grib_api-*-Source
src/LIB/netcdf4/hdf5-*/
src/LIB/netcdf4/netcdf-*/
src/LIB/netcdf4/curl-*/
src/LIB/netcdf4/zlib-*/
src/LIB/netcdf4/szip-*/
src/LIB/netcdf4/m4-*/

# Sortie de compilation ECOCLIMAP
MY_RUN/ECOCLIMAP/a.out
