# Archive XIOS (85 Mo) — dépendance tierce reconstructible, exclue du versionnement
# Récupérable depuis la distribution CNRM ou le dépôt XIOS (tag GMGEC-2152).
src/LIB/XIOS-GMGEC-2152.tar

# Binaires compilés (tout exe/ sauf le placeholder)
exe/*
!exe/empty.txt

# Artefacts de packaging Python
python/build/
python/dist/
python/*.egg-info/
**/__pycache__/
python/karpos_surfex/_surfex.c

# --- Artefacts de build générés par build.sh / configure ---
# Profils d'environnement générés
conf/profile_surfex
conf/profile_surfex-*
# Répertoire objets/modules
src/dir_obj-*/
# Sources tierces détarrées par configure (on garde les tarballs, pas les arbres extraits)
src/LIB/eccodes-*-Source/
src/LIB/grib_api-*-Source/
src/LIB/SPARTACUS_SURFACE_*/
src/LIB/netcdf4/*/
# Sorties de compilation de test ECOCLIMAP
MY_RUN/ECOCLIMAP/a.out
MY_RUN/ECOCLIMAP/*.bin
